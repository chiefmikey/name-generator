{
  "name": "name-generator",
  "version": "3.0.0",
  "type": "module",
  "description": "Fun social media name generator — pick your birthday, animal, and fruit to generate a unique name",
  "scripts": {
    "build:dev": "NODE_ENV=development webpack --mode development -w",
    "build:prod": "NODE_ENV=production webpack --mode production",
    "dev": "webpack serve --mode development --open",
    "fix": "eslint --fix '**/*'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@mikey-pro/eslint-config-vue": "^10.2.0",
    "@types/webpack": "^5.28.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.1",
    "@vue/babel-plugin-jsx": "^2.0.1",
    "@vue/compiler-sfc": "^3.5.28",
    "@vue/test-utils": "^2.4.6",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "happy-dom": "^20.8.8",
    "mikey-pro": "^10.3.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "vue-loader": "^17.4.2",
    "vue-style-loader": "^4.1.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "homepage": "https://github.com/chiefmikey/name-generator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiefmikey/name-generator.git"
  },
  "bugs": {
    "url": "https://github.com/chiefmikey/name-generator/issues"
  },
  "license": "MIT",
  "author": "Mikl Wolfe <wolfe@mikl.io> (https://mikl.io)",
  "browserslist": ["defaults"],
  "prettier": "mikey-pro/prettier",
  "stylelint": {
    "extends": "mikey-pro/stylelint"
  }
}
